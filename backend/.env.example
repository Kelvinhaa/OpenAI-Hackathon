OPENAI_API_KEY=your_openai_key_here
# Use the Supabase *session pooler* host, not the direct `db.<ref>.supabase.co` one.
# The direct host publishes only an AAAA record, and macOS getaddrinfo refuses to
# return it even on an IPv6-capable machine -- psycopg then fails with
# "failed to resolve host", which looks like the database is down. The pooler
# hostname has A records and resolves normally. Copy the exact string from
# Supabase -> Project Settings -> Database -> Connection string -> Session pooler;
# note the username carries the project ref (`postgres.<ref>`, not bare `postgres`).
# Port 5432 is session mode. Transaction mode (6543) also works but needs
# `?prepare_threshold=0`, because psycopg3 uses prepared statements by default and
# a transaction pooler cannot keep them across statements.
DATABASE_URL=postgresql+psycopg://postgres.xxxxxxxxxxxx:password@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_JWT_SECRET=your_jwt_secret_here
REDIS_URL=redis://default:password@host.db.redis.io:port
